generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CrawlStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model CrawlRun {
  id          String      @id @default(cuid())
  startUrl    String
  status      CrawlStatus @default(QUEUED)
  createdAt   DateTime    @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  pages       Page[]
  urls        CrawledUrl[]
}

model Page {
  id          String   @id @default(cuid())
  crawlRunId  String
  crawlRun    CrawlRun @relation(fields: [crawlRunId], references: [id], onDelete: Cascade)
  url         String
  title       String?
  rawHtml     String
  extractedText String
  contentHash String?

  statusCode  Int
  fetchedAt   DateTime @default(now())

  versions PageVersion[]

  @@index([crawlRunId])
  @@index([contentHash])
  @@index([url])
}

model PageVersion {
  id             String   @id @default(cuid())

  pageId         String
  page           Page     @relation(fields: [pageId],references: [id],onDelete: Cascade)

  contentHash    String
  rawHtml        String
  extractedText  String

  createdAt      DateTime @default(now())


  @@index([pageId])
  @@index([contentHash])  
}

model CrawledUrl {
  id          String          @id @default(cuid())
  url         String          
  crawlRunId  String

  status      CrawlUrlStatus  @default(PENDING)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  crawlRun CrawlRun @relation(fields: [crawlRunId], references: [id], onDelete: Cascade)

  @@unique([url, crawlRunId])
  @@index([crawlRunId])
  @@index([status])
}


enum CrawlUrlStatus {
  PENDING
  CRAWLING
  COMPLETED
  FAILED
}